// ----------------------------------------------------------------
//  Type alias — use long double everywhere
// ----------------------------------------------------------------
typedef long double ld;

// M_PIl is undefined in some toolchains — define it manually
#ifndef M_PIl
  static const ld M_PIl = 3.141592653589793238462643383279502884L;
#endif

// ----------------------------------------------------------------
//  Constants
// ----------------------------------------------------------------
static const ld G          = 9.80665L;       // m/s²
static const ld R_AIR      = 287.058L;       // J/(kg·K)
static const ld T0         = 288.15L;        // K  (sea level)
static const ld P0         = 101325.0L;      // Pa (sea level)
static const ld L          = 0.0065L;        // K/m lapse rate
static const ld ROKET_ITME = 1800.0L;        // N  (motor thrust)
static const ld ROKET_KG   = 12.0L;          // kg (launch mass)
static const ld YAKIT_KG   = 5.0L;           // kg (propellant mass)
static const ld MOTOR_SURE = 3.5L;           // s  (burn duration)
static const ld CD         = 0.45L;          // Drag coefficient
static const ld A_KESIT    = 0.008L;         // m² (cross-section ~10cm diameter)
static const ld DT         = 0.05L;          // s  (simulation step size)
static const int N_STATE   = 6;              // state dimension
static const int N_MEAS    = 4;              // measurement dimension

// ----------------------------------------------------------------
//  Matrix class (stack-allocated, fixed size)
// ----------------------------------------------------------------
template<int R, int C>
struct Mat {
  ld d[R][C];

  Mat() { zero(); }

  void zero() {
    for (int i = 0; i < R; i++)
      for (int j = 0; j < C; j++)
        d[i][j] = 0.0L;
  }

  void eye() {
    zero();
    int mn = R < C ? R : C;
    for (int i = 0; i < mn; i++) d[i][i] = 1.0L;
  }

  // Transpose
  Mat<C,R> T() const {
    Mat<C,R> out;
    for (int i = 0; i < R; i++)
      for (int j = 0; j < C; j++)
        out.d[j][i] = d[i][j];
    return out;
  }

  // Matrix multiplication
  template<int K>
  Mat<R,K> operator*(const Mat<C,K>& b) const {
    Mat<R,K> out;
    for (int i = 0; i < R; i++)
      for (int j = 0; j < K; j++)
        for (int k = 0; k < C; k++)
          out.d[i][j] += d[i][k] * b.d[k][j];
    return out;
  }

  // Addition
  Mat<R,C> operator+(const Mat<R,C>& b) const {
    Mat<R,C> out;
    for (int i = 0; i < R; i++)
      for (int j = 0; j < C; j++)
        out.d[i][j] = d[i][j] + b.d[i][j];
    return out;
  }

  // Subtraction
  Mat<R,C> operator-(const Mat<R,C>& b) const {
    Mat<R,C> out;
    for (int i = 0; i < R; i++)
      for (int j = 0; j < C; j++)
        out.d[i][j] = d[i][j] - b.d[i][j];
    return out;
  }

  // Scalar multiplication
  Mat<R,C> operator*(ld s) const {
    Mat<R,C> out;
    for (int i = 0; i < R; i++)
      for (int j = 0; j < C; j++)
        out.d[i][j] = d[i][j] * s;
    return out;
  }
};

// ----------------------------------------------------------------
//  Square matrix inverse — Gauss-Jordan elimination (long double)
// ----------------------------------------------------------------
template<int N>
Mat<N,N> matInv(const Mat<N,N>& A) {
  ld a[N][N], inv[N][N];
  for (int i = 0; i < N; i++)
    for (int j = 0; j < N; j++) {
      a[i][j]   = A.d[i][j];
      inv[i][j] = (i == j) ? 1.0L : 0.0L;
    }

  for (int col = 0; col < N; col++) {
    // Select pivot
    int pivot = col;
    for (int row = col+1; row < N; row++)
      if (fabsl(a[row][col]) > fabsl(a[pivot][col])) pivot = row;

    // Swap rows
    for (int j = 0; j < N; j++) {
      ld tmp  = a[col][j];   a[col][j]   = a[pivot][j];   a[pivot][j]   = tmp;
      tmp     = inv[col][j]; inv[col][j] = inv[pivot][j]; inv[pivot][j] = tmp;
    }

    ld div = a[col][col];
    if (fabsl(div) < 1e-30L) continue; // Singular matrix guard

    for (int j = 0; j < N; j++) {
      a[col][j]   /= div;
      inv[col][j] /= div;
    }

    for (int row = 0; row < N; row++) {
      if (row == col) continue;
      ld factor = a[row][col];
      for (int j = 0; j < N; j++) {
        a[row][j]   -= factor * a[col][j];
        inv[row][j] -= factor * inv[col][j];
      }
    }
  }

  Mat<N,N> out;
  for (int i = 0; i < N; i++)
    for (int j = 0; j < N; j++)
      out.d[i][j] = inv[i][j];
  return out;
}

// ----------------------------------------------------------------
//  Rocket physics model
// ----------------------------------------------------------------
struct RoketDurumu {
  ld zaman;       // s
  ld irtifa;      // m
  ld hiz;         // m/s  (vertical)
  ld ivme;        // m/s² (vertical)
  ld roll;        // rad
  ld pitch;       // rad
  ld yaw;         // rad
  ld roll_rate;   // rad/s
  ld pitch_rate;  // rad/s
  ld yaw_rate;    // rad/s
  ld kitle;       // kg
  bool motorAktif;
  bool apogee;
  bool indi;
};

// Compute pressure from altitude using ISA model (Pa)
ld irtifahaBasinc(ld h) {
  if (h < 0.0L) h = 0.0L;
  return P0 * powl(1.0L - L * h / T0, G / (R_AIR * L));
}

// Compute altitude from pressure (m)
ld basincaIrtifa(ld P) {
  if (P <= 0.0L) return 0.0L;
  return (T0 / L) * (1.0L - powl(P / P0, R_AIR * L / G));
}

// Air density (kg/m³)
ld yogunluk(ld h) {
  if (h < 0.0L) h = 0.0L;
  ld T = T0 - L * h;
  ld P = irtifahaBasinc(h);
  return P / (R_AIR * T);
}

// ----------------------------------------------------------------
//  Kalman Filter — Full 6-DOF
//  State: [altitude, vel_z, acc_z, roll, pitch, yaw]
// ----------------------------------------------------------------
struct KalmanFiltresi {
  // State vector
  Mat<6,1> x;   // [h, vz, az, roll, pitch, yaw]

  // Covariance matrix
  Mat<6,6> P;

  // Transition matrix F (6×6)
  Mat<6,6> F;

  // Process noise Q (6×6)
  Mat<6,6> Q;

  // Measurement matrix H (4×6)
  // Measurements: [baro1_altitude, baro2_altitude, acc_z1, acc_z2]
  Mat<4,6> H;

  // Measurement noise R (4×4)
  Mat<4,4> R_mat;

  // Kalman gain K (6×4)
  Mat<6,4> K;

  // Last innovation
  Mat<4,1> inovasyon;

  void baslat(ld baslangic_irtifa) {
    // Initial state
    x.zero();
    x.d[0][0] = baslangic_irtifa;

    // Initial covariance — large uncertainty
    P.eye();
    P.d[0][0] = 10.0L;    // altitude uncertainty (m²)
    P.d[1][1] = 1.0L;     // velocity uncertainty
    P.d[2][2] = 0.5L;     // acceleration uncertainty
    P.d[3][3] = 0.01L;    // roll uncertainty
    P.d[4][4] = 0.01L;    // pitch uncertainty
    P.d[5][5] = 0.01L;    // yaw uncertainty

    // Process noise Q
    Q.zero();
    Q.d[0][0] = 0.1L;
    Q.d[1][1] = 0.5L;
    Q.d[2][2] = 1.0L;
    Q.d[3][3] = 0.001L;
    Q.d[4][4] = 0.001L;
    Q.d[5][5] = 0.001L;

    // Measurement matrix H
    // baro1 → altitude
    H.d[0][0] = 1.0L;
    // baro2 → altitude (fusion)
    H.d[1][0] = 1.0L;
    // acc1 → acc_z
    H.d[2][2] = 1.0L;
    // acc2 → acc_z
    H.d[3][2] = 1.0L;

    // Measurement noise R
    // BMP390 class: ~±0.5m altitude resolution → σ²=0.25
    R_mat.zero();
    R_mat.d[0][0] = 0.25L;   // baro1
    R_mat.d[1][1] = 0.30L;   // baro2 (slightly noisier)
    R_mat.d[2][2] = 0.04L;   // ivme1 (σ=0.2 m/s²)
    R_mat.d[3][3] = 0.05L;   // ivme2
  }

  // Update transition matrix for dt
  void gecisMatrisiGuncelle(ld dt) {
    F.eye();
    // Kinematics: h += vz*dt + 0.5*az*dt²
    F.d[0][1] = dt;
    F.d[0][2] = 0.5L * dt * dt;
    // vz += az*dt
    F.d[1][2] = dt;
    // Angular: roll += roll_rate*dt  (simplified)
    // Angular rates not tracked separately — yaw/pitch/roll driven by noise model
    // Can be extended later
  }

  // Predict step
  void tahmin(ld dt, ld dis_ivme) {
    gecisMatrisiGuncelle(dt);

    // Control input: external acceleration (thrust + gravity + drag)
    Mat<6,1> u;
    u.d[2][0] = dis_ivme;  // acceleration injected directly into acceleration state

    // x = F*x + u
    x = F * x + u;

    // P = F*P*Fᵀ + Q
    P = F * P * F.T() + Q;
  }

  // Update step — with 4 measurements
  void guncelle(ld baro1_h, ld baro2_h, ld acc1_z, ld acc2_z) {
    Mat<4,1> z;
    z.d[0][0] = baro1_h;
    z.d[1][0] = baro2_h;
    z.d[2][0] = acc1_z;
    z.d[3][0] = acc2_z;

    // Innovation: y = z - H*x
    inovasyon = z - H * x;

    // Innovation covariance: S = H*P*Hᵀ + R
    Mat<4,4> S = H * P * H.T() + R_mat;

    // Kalman gain: K = P*Hᵀ*S⁻¹
    K = P * H.T() * matInv<4>(S);

    // State update: x = x + K*y
    x = x + K * inovasyon;

    // Covariance update: P = (I - K*H)*P
    Mat<6,6> I; I.eye();
    P = (I - K * H) * P;
  }

  ld irtifa()   const { return x.d[0][0]; }
  ld hiz()      const { return x.d[1][0]; }
  ld ivme()     const { return x.d[2][0]; }
  ld roll()     const { return x.d[3][0]; }
  ld pitch()    const { return x.d[4][0]; }
  ld yaw()      const { return x.d[5][0]; }
};

// ----------------------------------------------------------------
//  Sensor simulation — Gaussian noise (Box-Muller)
// ----------------------------------------------------------------
ld gaussGurultu(ld sigma) {
  static bool hazir = false;
  static ld   yedek = 0.0L;
  if (hazir) { hazir = false; return yedek * sigma; }
  ld u1 = (ld)random(1, 1000000) / 1000000.0L;
  ld u2 = (ld)random(1, 1000000) / 1000000.0L;
  ld z0 = sqrtl(-2.0L * logl(u1)) * cosl(2.0L * M_PIl * u2);
  ld z1 = sqrtl(-2.0L * logl(u1)) * sinl(2.0L * M_PIl * u2);
  yedek = z1; hazir = true;
  return z0 * sigma;
}

