// ----------------------------------------------------------------
//  setup & loop
// ----------------------------------------------------------------
void setup() {
  Serial.begin(115200);
  while (!Serial && millis() < 3000);  // wait for USB connection

  // init LCD
  Wire.begin();
  Wire.setClock(400000);
  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Roket Kalman");
  lcd.setCursor(0, 1);
  lcd.print("Teensy 4.1 6DOF");
  delay(2000);
  lcd.clear();

  randomSeed(analogRead(A0) ^ micros());

  simReset();
  yardim();
  Serial.println(F(">> Type 'start' and press Enter."));

  // show wait screen on LCD
  lcd.setCursor(0, 0);
  lcd.print("'start' yazin");
  lcd.setCursor(0, 1);
  lcd.print("Serial Monitor");
}

void loop() {
  if (!Serial.available()) return;

  String cmd = Serial.readStringUntil('\n');
  cmd.trim();
  cmd.toLowerCase();

  if (cmd == "help") {
    yardim();

  } else if (cmd == "start") {
    if (!simBasladi) {
      simBasladi = true;
      lcdSayfa   = 0;
      lcdSayfaMs = 0;
      lcd.clear();
      Serial.println(F(">> Simulation started! Rocket igniting..."));
      lcd.setCursor(0, 0);
      lcd.print("Roket ateslen.");
      lcd.setCursor(0, 1);
      lcd.print("Hazir!");
      delay(800);
      lcd.clear();
    } else {
      Serial.println(F(">> Already running. Type 'reset' to restart."));
    }

  } else if (cmd == "step") {
    if (!simBasladi) { Serial.println(F(">> Type 'start' first.")); return; }
    if (roket.indi)  { Serial.println(F(">> Roket indi. 'reset' ile resetyın.")); return; }
    roketAdim();
    kalmanAdim();
    adimSayisi++;
    durumYaz();
    lcdGuncelle();

  } else if (cmd.startsWith("run")) {
    if (!simBasladi) { Serial.println(F(">> Type 'start' first.")); return; }

    String arg = cmd.substring(4);
    arg.trim();

    int n = 0;
    bool full = (arg == "full");
    if (!full) n = arg.toInt();
    if (!full && n <= 0) { Serial.println(F(">> Invalid number. Example: run 80")); return; }

    int sayac = 0;
    while (!roket.indi) {
      if (!full && sayac >= n) break;
      roketAdim();
      kalmanAdim();
      adimSayisi++;
      sayac++;

      // update LCD every step
      lcdGuncelle();

      // write to Serial every 20 steps (prevents buffer overflow)
      if (sayac % 20 == 0 || roket.indi) {
        durumYaz();
        delay(10);
      }
    }
    Serial.print(F(">> ")); Serial.print(sayac);
    Serial.println(F(" steps done."));
    if (roket.indi) {
      Serial.println(F(">> ✓ Rocket landed! Flight complete."));
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("INIS TAMAMLANDI");
      lcd.setCursor(0, 1);
      lcd.print("t=");
      lcd.print((double)roket.zaman, 1);
      lcd.print("s  'reset'");
    }

  } else if (cmd == "status") {
    durumYaz();
    lcdGuncelle();

  } else if (cmd == "reset") {
    simReset();
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Sifirlandi.");
    lcd.setCursor(0, 1);
    lcd.print("'start' bekliyor");

  } else if (cmd.length() > 0) {
    Serial.print(F(">> Unknown command: '"));
    Serial.print(cmd);
    Serial.println(F("'  — type 'help'."));
  }
}
