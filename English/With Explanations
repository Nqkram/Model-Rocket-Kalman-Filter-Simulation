  Serial.print(F("│  Apogee   : ")); Serial.println(roket.apogee ? F("PASSED ▼") : F("Not yet ▲"));
  Serial.print(F("│  Elapsed  : ")); Serial.print(islem_us); Serial.println(F(" µs"));
  Serial.println(F("└─────────────────────────────────────────────────────┘"));
  Serial.println();
}

// ----------------------------------------------------------------
//  Simulation reset
// ----------------------------------------------------------------
void simReset() {
  roket.zaman     = 0.0L;
  roket.irtifa    = 0.0L;
  roket.hiz       = 0.0L;
  roket.ivme      = 0.0L;
  roket.roll      = 0.0L;
  roket.pitch     = 0.0L;
  roket.yaw       = 0.0L;
  roket.roll_rate = 0.0L;
  roket.pitch_rate= 0.0L;
  roket.yaw_rate  = 0.0L;
  roket.kitle     = ROKET_KG;
  roket.motorAktif= false;
  roket.apogee    = false;
  roket.indi      = false;
  kalman.baslat(0.0L);
  simBasladi = false;
  adimSayisi = 0;
  Serial.println(F(">> Simulation reset."));
}

