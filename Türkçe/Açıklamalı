  Serial.print(F("│  K[2,2] İvme    : ")); Serial.println((double)K_22, 6);
  Serial.println(F("├─────────────────────────────────────────────────────┤"));
  Serial.println(F("│  İNOVASYON (ölçüm - tahmin farkı)"));
  Serial.print(F("│  Δ Baro1  : ")); Serial.print((double)kalman.inovasyon.d[0][0], 4); Serial.println(F(" m"));
  Serial.print(F("│  Δ Baro2  : ")); Serial.print((double)kalman.inovasyon.d[1][0], 4); Serial.println(F(" m"));
  Serial.print(F("│  Δ Acc1   : ")); Serial.print((double)kalman.inovasyon.d[2][0], 4); Serial.println(F(" m/s²"));
  Serial.print(F("│  Δ Acc2   : ")); Serial.print((double)kalman.inovasyon.d[3][0], 4); Serial.println(F(" m/s²"));
  Serial.println(F("├─────────────────────────────────────────────────────┤"));
  Serial.println(F("│  SİSTEM"));
  Serial.print(F("│  Motor   : ")); Serial.println(roket.motorAktif ? F("AKTİF 🔥") : F("SÖNDÜ"));
  Serial.print(F("│  Apogee  : ")); Serial.println(roket.apogee ? F("GEÇİLDİ ▼") : F("Henüz değil ▲"));
  Serial.print(F("│  İşlem   : ")); Serial.print(islem_us); Serial.println(F(" µs"));
  Serial.println(F("└─────────────────────────────────────────────────────┘"));
  Serial.println();
}

// ----------------------------------------------------------------
//  Simülasyon sıfırlama
// ----------------------------------------------------------------
void simReset() {
  roket.zaman     = 0.0L;
  roket.irtifa    = 0.0L;
  roket.hiz       = 0.0L;
  roket.ivme      = 0.0L;
  roket.roll      = 0.0L;
  roket.pitch     = 0.0L;
  roket.yaw       = 0.0L;
  roket.roll_rate = 0.0L;
  roket.pitch_rate= 0.0L;
  roket.yaw_rate  = 0.0L;
  roket.kitle     = ROKET_KG;
  roket.motorAktif= false;
  roket.apogee    = false;
  roket.indi      = false;
  kalman.baslat(0.0L);
  simBasladi = false;
  adimSayisi = 0;
  Serial.println(F(">> Simülasyon sıfırlandı."));
}

