// ----------------------------------------------------------------
//  setup & loop
// ----------------------------------------------------------------
void setup() {
  Serial.begin(115200);
  while (!Serial && millis() < 3000);  // USB bağlantısını bekle

  // LCD başlat
  Wire.begin();
  Wire.setClock(400000);
  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Roket Kalman");
  lcd.setCursor(0, 1);
  lcd.print("Teensy 4.1 6DOF");
  delay(2000);
  lcd.clear();

  randomSeed(analogRead(A0) ^ micros());

  simReset();
  yardim();
  Serial.println(F(">> 'start' yazıp Enter'a basın."));

  // LCD'ye bekleme ekranı
  lcd.setCursor(0, 0);
  lcd.print("'start' yazin");
  lcd.setCursor(0, 1);
  lcd.print("Serial Monitor");
}

void loop() {
  if (!Serial.available()) return;

  String cmd = Serial.readStringUntil('\n');
  cmd.trim();
  cmd.toLowerCase();

  if (cmd == "help") {
    yardim();

  } else if (cmd == "start") {
    if (!simBasladi) {
      simBasladi = true;
      lcdSayfa   = 0;
      lcdSayfaMs = 0;
      lcd.clear();
      Serial.println(F(">> Simülasyon başladı! Roket ateşleniyor..."));
      lcd.setCursor(0, 0);
      lcd.print("Roket ateslen.");
      lcd.setCursor(0, 1);
      lcd.print("Hazir!");
      delay(800);
      lcd.clear();
    } else {
      Serial.println(F(">> Zaten başladı. 'reset' ile sıfırlayın."));
    }

  } else if (cmd == "step") {
    if (!simBasladi) { Serial.println(F(">> Önce 'start' yazın.")); return; }
    if (roket.indi)  { Serial.println(F(">> Roket indi. 'reset' ile sıfırlayın.")); return; }
    roketAdim();
    kalmanAdim();
    adimSayisi++;
    durumYaz();
    lcdGuncelle();

  } else if (cmd.startsWith("run")) {
    if (!simBasladi) { Serial.println(F(">> Önce 'start' yazın.")); return; }

    String arg = cmd.substring(4);
    arg.trim();

    int n = 0;
    bool full = (arg == "full");
    if (!full) n = arg.toInt();
    if (!full && n <= 0) { Serial.println(F(">> Geçersiz sayı. Örnek: run 80")); return; }

    int sayac = 0;
    while (!roket.indi) {
      if (!full && sayac >= n) break;
      roketAdim();
      kalmanAdim();
      adimSayisi++;
      sayac++;

      // LCD her adımda güncelle
      lcdGuncelle();

      // Serial her 20 adımda bir yaz (buffer taşmasını önler)
      if (sayac % 20 == 0 || roket.indi) {
        durumYaz();
        delay(10);
      }
    }
    Serial.print(F(">> ")); Serial.print(sayac);
    Serial.println(F(" adım tamamlandı."));
    if (roket.indi) {
      Serial.println(F(">> ✓ Roket yere indi! Uçuş tamamlandı."));
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("INIS TAMAMLANDI");
      lcd.setCursor(0, 1);
      lcd.print("t=");
      lcd.print((double)roket.zaman, 1);
      lcd.print("s  'reset'");
    }

  } else if (cmd == "status") {
    durumYaz();
    lcdGuncelle();

  } else if (cmd == "reset") {
    simReset();
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Sifirlandi.");
    lcd.setCursor(0, 1);
    lcd.print("'start' bekliyor");

  } else if (cmd.length() > 0) {
    Serial.print(F(">> Bilinmeyen komut: '"));
    Serial.print(cmd);
    Serial.println(F("'  — 'help' yazın."));
  }
}
